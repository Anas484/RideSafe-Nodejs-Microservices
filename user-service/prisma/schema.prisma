generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum driverStatus {
  ACTIVE
  INACTIVE
  IN_RIDE
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  firstName String
  lastName  String
  password  String
  role      String   @default("PASSENGER")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  driver    Driver?
  passenger Passenger?
}


model Driver {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique
  status    driverStatus @default(INACTIVE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
}


model Passenger {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
}